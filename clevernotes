#!/usr/bin/env bash
# clevernotes launcher — activates the venv and runs the CLI module from the user's CWD.
set -e

CN_HOME="${CLEVERNOTES_HOME:-$HOME/.local/share/clevernotes}"
VENV="$CN_HOME/venv"

if [ ! -d "$VENV" ]; then
  echo "clevernotes: venv not found at $VENV" >&2
  echo "re-run install.sh to set things up." >&2
  exit 1
fi

# macOS: BasicTeX adds /Library/TeX/texbin via /etc/paths.d/, but that's only
# picked up by new login shells. If the user ran install.sh and `clevernotes`
# in the same terminal, xelatex won't be on PATH and Stage 4 (md→PDF) skips.
# Refresh PATH via path_helper so the launcher self-heals.
if [ "$(uname -s)" = "Darwin" ] && [ -x /usr/libexec/path_helper ]; then
  eval "$(/usr/libexec/path_helper -s)"
fi

# shellcheck disable=SC1091
. "$VENV/bin/activate"

export PYTHONPATH="$CN_HOME/src:${PYTHONPATH:-}"
exec python -m clevernotes "$@"
